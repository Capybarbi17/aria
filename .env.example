# From Supabase Dashboard → Project Settings → API
# Use Project URL and the publishable (or anon) key — NOT the service_role key
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your_publishable_or_anon_key
VITE_OPENAI_API_KEY=your_openai_api_key
# AI analysis uses OpenAI gpt-4o-mini (see src/lib/ai.js)

# Auth: new org accounts are auto-confirmed via DB migration (no email link required).
# Optional — stop confirmation emails entirely:
# Dashboard → Authentication → Providers → Email → turn OFF "Confirm email"
